# 数据库（开发使用 SQLite，生产可切换为 PostgreSQL）
DATABASE_URL="file:./dev.db"

# 服务端密钥（必须设置，长度至少 16 字符，生产环境建议 32+ 字符）
JWT_SECRET="please-change-this-to-a-random-secret-key-at-least-16-chars"
PORT=3001

# CORS 白名单（逗号分隔，包含所有可能的前端端口）
CORS_ORIGIN="http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174,http://localhost:5175,http://127.0.0.1:5175,http://localhost:5176,http://127.0.0.1:5176,http://localhost:4173"

# 文件存储
UPLOAD_DIR="./uploads"

# 可选：服务端默认 AI 配置（用户也可以在设置里配置自己的 Key）
# 智谱 GLM: https://open.bigmodel.cn/
GLM_API_KEY=""
GLM_BASE_URL="https://open.bigmodel.cn/api/paas/v4"

# DeepSeek: https://platform.deepseek.com/
DEEPSEEK_API_KEY=""
DEEPSEEK_BASE_URL="https://api.deepseek.com"

# Kimi (Moonshot): https://platform.moonshot.cn/
KIMI_API_KEY=""
KIMI_BASE_URL="https://api.moonshot.cn/v1"
