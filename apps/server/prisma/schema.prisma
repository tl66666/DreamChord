generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  username      String    @unique
  password      String
  nickname      String?
  avatar        String?
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  projects      Project[]
  comments      Comment[]
  agentConversations AgentConversation[]
  agentRuns     AgentRun[]

  @@map("users")
}

model Project {
  id            String    @id @default(uuid())
  title         String
  description   String?
  cover         String    @default("/assets/covers/default-cover.png")
  isPublic      Boolean   @default(false) @map("is_public")
  isPublished   Boolean   @default(false) @map("is_published")
  playCount     Int       @default(0) @map("play_count")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  authorId      String    @map("author_id")
  author        User      @relation(fields: [authorId], references: [id], onDelete: Cascade)

  chapters      Chapter[]
  characters    Character[]
  assets        Asset[]
  comments      Comment[]
  storyBible    StoryBible?
  agentConversations AgentConversation[]
  agentRuns     AgentRun[]
  storyPatches  StoryPatch[]

  @@index([authorId])
  @@map("projects")
}

model Chapter {
  id            String    @id @default(uuid())
  title         String    @default("未命名章节")
  order         Int       @default(0)
  version       Int       @default(1)
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  projectId     String    @map("project_id")
  project       Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  nodes         FlowNode[]
  edges         FlowEdge[]
  agentRuns     AgentRun[]
  storyPatches  StoryPatch[]
  snapshots     ChapterSnapshot[]

  @@index([projectId])
  @@map("chapters")
}

model FlowNode {
  id            String    @id @default(uuid())
  nodeId        String    @map("node_id")
  type          String
  positionX     Float     @map("position_x")
  positionY     Float     @map("position_y")
  data          String

  chapterId     String    @map("chapter_id")
  chapter       Chapter   @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@index([chapterId])
  @@unique([chapterId, nodeId])
  @@map("flow_nodes")
}

model FlowEdge {
  id            String    @id @default(uuid())
  edgeId        String    @map("edge_id")
  source        String
  target        String
  label         String?
  sourceHandle  String?   @map("source_handle")
  animated      Boolean   @default(true)

  chapterId     String    @map("chapter_id")
  chapter       Chapter   @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@index([chapterId])
  @@unique([chapterId, edgeId])
  @@map("flow_edges")
}

model Character {
  id            String    @id @default(uuid())
  name          String
  description   String?
  color         String    @default("#8b5cf6")
  defaultSprite String    @default("/assets/characters/default-avatar.png") @map("default_sprite")
  createdAt     DateTime  @default(now()) @map("created_at")

  projectId     String    @map("project_id")
  project       Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  sprites       Sprite[]

  @@index([projectId])
  @@unique([projectId, name])
  @@map("characters")
}

model Sprite {
  id            String    @id @default(uuid())
  name          String    @default("default")
  url           String

  characterId   String    @map("character_id")
  character     Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@index([characterId])
  @@map("sprites")
}

model Asset {
  id            String    @id @default(uuid())
  name          String
  type          String    @default("OTHER")
  url           String
  createdAt     DateTime  @default(now()) @map("created_at")

  projectId     String    @map("project_id")
  project       Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("assets")
}

model Comment {
  id            String    @id @default(uuid())
  content       String
  createdAt     DateTime  @default(now()) @map("created_at")

  authorId      String    @map("author_id")
  author        User      @relation(fields: [authorId], references: [id], onDelete: Cascade)

  projectId     String    @map("project_id")
  project       Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([authorId])
  @@map("comments")
}

model StoryBible {
  id        String   @id @default(uuid())
  content   String   @default("{}")
  version   Int      @default(1)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  projectId String  @unique @map("project_id")
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("story_bibles")
}

model AgentConversation {
  id        String   @id @default(uuid())
  title     String
  scope     String
  chapterId String?  @map("chapter_id")
  isPinned  Boolean  @default(false) @map("is_pinned")
  summary   String   @default("")
  summaryThroughMessageId String? @map("summary_through_message_id")
  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  userId    String  @map("user_id")
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId String  @map("project_id")
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  messages AgentMessage[]
  runs     AgentRun[]

  @@index([userId, projectId])
  @@map("agent_conversations")
}

model AgentMessage {
  id        String   @id @default(uuid())
  role      String
  content   String
  metadata  String   @default("{}")
  createdAt DateTime @default(now()) @map("created_at")

  conversationId String            @map("conversation_id")
  conversation   AgentConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("agent_messages")
}

model AgentRun {
  id            String    @id @default(uuid())
  status        String    @default("queued")
  prompt        String
  scope         String
  targetId      String?   @map("target_id")
  provider      String
  model         String
  plan          String    @default("[]")
  timeline      String    @default("[]")
  sources       String    @default("[]")
  validation    String    @default("{}")
  errorCode     String?   @map("error_code")
  errorMessage  String?   @map("error_message")
  usage         String    @default("{}")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  completedAt   DateTime? @map("completed_at")

  userId         String            @map("user_id")
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId      String            @map("project_id")
  project        Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  chapterId      String?           @map("chapter_id")
  chapter        Chapter?          @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  conversationId String            @map("conversation_id")
  conversation   AgentConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  patch           StoryPatch?

  @@index([userId, projectId])
  @@index([status])
  @@index([conversationId, createdAt])
  @@map("agent_runs")
}

model StoryPatch {
  id             String    @id @default(uuid())
  payload        String
  validation     String    @default("{}")
  diff           String    @default("{}")
  status         String    @default("proposed")
  baseVersion    Int       @map("base_version")
  appliedVersion Int?      @map("applied_version")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  runId     String   @unique @map("run_id")
  run       AgentRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  projectId String   @map("project_id")
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  chapterId String   @map("chapter_id")
  chapter   Chapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  snapshot  ChapterSnapshot?

  @@index([projectId, chapterId])
  @@index([status])
  @@map("story_patches")
}

model ChapterSnapshot {
  id        String   @id @default(uuid())
  nodes     String
  edges     String
  version   Int
  createdAt DateTime @default(now()) @map("created_at")

  patchId   String     @unique @map("patch_id")
  patch     StoryPatch @relation(fields: [patchId], references: [id], onDelete: Cascade)
  chapterId String     @map("chapter_id")
  chapter   Chapter    @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@index([chapterId])
  @@map("chapter_snapshots")
}
