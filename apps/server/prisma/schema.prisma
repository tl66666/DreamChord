generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  username      String    @unique
  password      String
  nickname      String?
  avatar        String?
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  projects      Project[]
  comments      Comment[]
  aiConfigs     AIProviderConfig[]

  @@map("users")
}

model Project {
  id            String    @id @default(uuid())
  title         String
  description   String?
  cover         String    @default("/assets/covers/default-cover.png")
  isPublic      Boolean   @default(false) @map("is_public")
  isPublished   Boolean   @default(false) @map("is_published")
  playCount     Int       @default(0) @map("play_count")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  authorId      String    @map("author_id")
  author        User      @relation(fields: [authorId], references: [id], onDelete: Cascade)

  chapters      Chapter[]
  characters    Character[]
  assets        Asset[]
  comments      Comment[]

  @@index([authorId])
  @@map("projects")
}

model Chapter {
  id            String    @id @default(uuid())
  title         String    @default("未命名章节")
  order         Int       @default(0)
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  projectId     String    @map("project_id")
  project       Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  nodes         FlowNode[]
  edges         FlowEdge[]

  @@index([projectId])
  @@map("chapters")
}

model FlowNode {
  id            String    @id @default(uuid())
  nodeId        String    @map("node_id")
  type          String
  positionX     Float     @map("position_x")
  positionY     Float     @map("position_y")
  data          String

  chapterId     String    @map("chapter_id")
  chapter       Chapter   @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@index([chapterId])
  @@unique([chapterId, nodeId])
  @@map("flow_nodes")
}

model FlowEdge {
  id            String    @id @default(uuid())
  edgeId        String    @map("edge_id")
  source        String
  target        String
  label         String?
  sourceHandle  String?   @map("source_handle")
  animated      Boolean   @default(true)

  chapterId     String    @map("chapter_id")
  chapter       Chapter   @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@index([chapterId])
  @@unique([chapterId, edgeId])
  @@map("flow_edges")
}

model Character {
  id            String    @id @default(uuid())
  name          String
  description   String?
  color         String    @default("#8b5cf6")
  defaultSprite String    @default("/assets/characters/default-avatar.png") @map("default_sprite")
  createdAt     DateTime  @default(now()) @map("created_at")

  projectId     String    @map("project_id")
  project       Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  sprites       Sprite[]

  @@index([projectId])
  @@unique([projectId, name])
  @@map("characters")
}

model Sprite {
  id            String    @id @default(uuid())
  name          String    @default("default")
  url           String

  characterId   String    @map("character_id")
  character     Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@index([characterId])
  @@map("sprites")
}

model Asset {
  id            String    @id @default(uuid())
  name          String
  type          String    @default("OTHER")
  url           String
  createdAt     DateTime  @default(now()) @map("created_at")

  projectId     String    @map("project_id")
  project       Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("assets")
}

model Comment {
  id            String    @id @default(uuid())
  content       String
  createdAt     DateTime  @default(now()) @map("created_at")

  authorId      String    @map("author_id")
  author        User      @relation(fields: [authorId], references: [id], onDelete: Cascade)

  projectId     String    @map("project_id")
  project       Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([authorId])
  @@map("comments")
}

model AIProviderConfig {
  id            String    @id @default(uuid())
  provider      String
  apiKey        String    @map("api_key")
  baseUrl       String?   @map("base_url")
  model         String
  isEnabled     Boolean   @default(true) @map("is_enabled")
  isDefault     Boolean   @default(false) @map("is_default")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  userId        String    @map("user_id")
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@unique([userId, provider])
  @@map("ai_provider_configs")
}
